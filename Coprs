<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=1200" />
<title>BOUKAMI — Investissez dans les projets ivoiriens</title>
<style>
  :root{
    --blue:#0b3b66;
    --gold:#d2a33a;
    --muted:#6b7280;
    --card:#ffffff;
    --bg:#f7fafc;
    --radius:12px;
    font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
  }
  html,body{height:100%;margin:0;background:var(--bg);color:var(--blue)}
  .container{width:1150px;margin:40px auto}
  header{display:flex;align-items:center;justify-content:space-between;padding:18px 0}
  .brand{display:flex;align-items:center;gap:12px}
  .logo{width:56px;height:56px;border-radius:10px;background:linear-gradient(135deg,var(--gold),#e9c87a);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--blue)}
  nav a{margin:0 14px;color:var(--blue);text-decoration:none;font-weight:600}
  .cta{background:var(--blue);color:#fff;padding:10px 16px;border-radius:10px;text-decoration:none;font-weight:700}
  .hero{display:flex;gap:36px;align-items:center;margin-top:28px}
  .hero-left{flex:1}
  h1{font-size:44px;margin:0 0 14px 0;line-height:1.03}
  p.lead{color:var(--muted);margin:0 0 22px 0;font-size:15px}
  .hero-ctas{display:flex;gap:12px}
  .btn-prim{background:linear-gradient(90deg,var(--gold),#c9992a);padding:12px 20px;border-radius:10px;color:#fff;font-weight:700;text-decoration:none}
  .stats{display:flex;gap:28px;margin-top:28px}
  .stat{background:var(--card);padding:18px;border-radius:12px;box-shadow:0 6px 18px rgba(11,59,102,0.06);min-width:160px;text-align:center}
  .stat .num{font-size:20px;font-weight:800;color:var(--blue)}
  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:32px}
  .card{background:var(--card);padding:18px;border-radius:12px;box-shadow:0 6px 18px rgba(11,59,102,0.06)}
  .card h3{margin:0 0 8px 0;color:var(--blue)}
  footer{margin-top:48px;padding:28px 0;border-top:1px solid #e6eef6;color:var(--muted);display:flex;justify-content:space-between;align-items:center}
  /* project list */
  .projects{margin-top:28px;display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .proj{background:#fff;padding:14px;border-radius:10px;border:1px solid #eef3fa}
  .proj h4{margin:0 0 6px 0}
  .proj .meta{font-size:13px;color:var(--muted);margin-bottom:8px}
  .progress{height:10px;background:#eef3fa;border-radius:999px;overflow:hidden}
  .fill{height:100%;background:linear-gradient(90deg,var(--gold),#c9992a)}
  /* simple dashboard link */
  .dashboard{margin-top:22px;padding:16px;border-radius:10px;background:linear-gradient(180deg,#fff,#fcfdff);display:flex;justify-content:space-between;align-items:center;border:1px solid #eef6ff}
  .small{font-size:13px;color:var(--muted)}
  /* responsive fallback */
  @media(max-width:1200px){.container{width:92%} .grid{grid-template-columns:1fr} .projects{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="container">
  <header>
    <div class="brand">
      <div class="logo">B</div>
      <div>
        <div style="font-weight:800;font-size:18px;color:var(--blue)">BOUKAMI S.A.</div>
        <div style="font-size:12px;color:var(--muted)">Investissez dans les projets ivoiriens</div>
      </div>
    </div>
    <nav>
      <a href="#apropos">À propos</a>
      <a href="#projets">Projets</a>
      <a href="#investir">Investir</a>
      <a href="#contact">Contact</a>
      <a class="cta" href="#connexion">Se connecter</a>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="hero-left">
        <h1>Investissez directement dans des projets ivoiriens.</h1>
        <p class="lead">BOUKAMI connecte les entrepreneurs ivoiriens et les citoyens-investisseurs. Plateforme sécurisée, transparente et dédiée au développement local.</p>
        <div class="hero-ctas">
          <a class="btn-prim" href="#investir">Investir maintenant</a>
          <a class="btn-prim" style="background:#fff;color:var(--blue);border:1px solid #e6eef6" href="#projets">Voir les projets</a>
        </div>

        <div class="stats" aria-hidden="true">
          <div class="stat"><div class="num">0</div><div class="small">Projets financés</div></div>
          <div class="stat"><div class="num">0</div><div class="small">Investisseurs</div></div>
          <div class="stat"><div class="num">0 FCFA</div><div class="small">Collectés</div></div>
        </div>

      </div>

      <div style="flex:0 0 420px">
        <div style="background:#fff;border-radius:12px;padding:20px;box-shadow:0 8px 28px rgba(11,59,102,0.06)">
          <div style="font-weight:700;font-size:16px;margin-bottom:8px">Tableau de bord — Investisseur</div>
          <div class="dashboard">
            <div>
              <div style="font-weight:700">Portefeuille</div>
              <div class="small">Solde disponible</div>
              <div style="font-size:20px;font-weight:800;margin-top:6px">0 FCFA</div>
            </div>
            <div style="text-align:right">
              <div class="small">Investissements</div>
              <div style="font-weight:700;font-size:20px">0</div>
            </div>
          </div>

          <div style="margin-top:12px">
            <a class="cta" href="#investir" style="display:inline-block">Commencer à investir</a>
          </div>
        </div>
      </div>
    </section>

    <section id="apropos" style="margin-top:44px">
      <div class="grid">
        <div class="card">
          <h3>Notre mission</h3>
          <p class="small">Soutenir les projets ivoiriens via une plateforme numérique d'investissement participatif. Les investisseurs ciblés sont avant tout la population ivoirienne.</p>
        </div>
        <div class="card">
          <h3>Pourquoi Boukami</h3>
          <p class="small">Priorité aux jeunes, transparence, contrôle local et accompagnement des porteurs.</p>
        </div>
        <div class="card">
          <h3>Conformité</h3>
          <p class="small">Conforme aux exigences locales. Compte séquestre, KYC/AML et reporting régulier.</p>
        </div>
      </div>
    </section>

    <section id="projets" style="margin-top:36px">
      <h2 style="margin:0 0 12px 0;color:var(--blue)">Projets en vedette</h2>
      <div class="projects" aria-live="polite">
        <article class="proj">
          <h4>Agriculture durable — Adom Farm</h4>
          <div class="meta">Objectif 6 000 000 FCFA • 40 jours restants</div>
          <div class="progress"><div class="fill" style="width:42%"></div></div>
        </article>
        <article class="proj">
          <h4>Atelier moto — Ben Motors</h4>
          <div class="meta">Objectif 3 500 000 FCFA • 21 jours restants</div>
          <div class="progress"><div class="fill" style="width:18%"></div></div>
        </article>
        <article class="proj">
          <h4>Application e-santé — Yélé</h4>
          <div class="meta">Objectif 10 000 000 FCFA • 60 jours restants</div>
          <div class="progress"><div class="fill" style="width:53%"></div></div>
        </article>
      </div>
    </section>

    <section id="investir" style="margin-top:34px">
      <h2 style="color:var(--blue)">Comment investir</h2>
      <div style="display:flex;gap:18px;margin-top:12px">
        <div class="card" style="flex:1">
          <h3>1. Créez un compte</h3>
          <p class="small">Inscription KYC rapide. Documents requis : CNI, justificatif adresse.</p>
        </div>
        <div class="card" style="flex:1">
          <h3>2. Choisissez un projet</h3>
          <p class="small">Consultez la due diligence et le plan financier avant d’investir.</p>
        </div>
        <div class="card" style="flex:1">
          <h3>3. Suivez</h3>
          <p class="small">Reporting trimestriel. Paiements en FCFA via mobile-money ou banque.</p>
        </div>
      </div>
    </section>

  </main>

  <footer>
    <div>© BOUKAMI S.A. — Abidjan</div>
    <div style="text-align:right">Contact : <span style="color:var(--muted)">noelepokou@gmail.com</span></div>
  </footer>

</div>

<script>
  // simple demo: animate stats to sample numbers
  document.addEventListener('DOMContentLoaded',()=>{
    const nums=[27,1205,'150M FCFA'];
    const statEls=document.querySelectorAll('.stat .num');
    statEls.forEach((el,i)=>{
      if(!nums[i]) return;
      if(typeof nums[i] === 'number'){
        let n=0; const target=nums[i];
        const id=setInterval(()=>{ n+= Math.ceil(target/30); if(n>=target){ el.textContent=target; clearInterval(id)} else el.textContent=n},30)
      } else el.textContent=nums[i];
    })
  })
</script>
</body>
</html>
